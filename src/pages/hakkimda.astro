---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { u } from "~/lib/url";
---

<BaseLayout
  title="Hakkımda"
  description="Berk Akkoç hakkında — tasarım yaklaşımı, eğitim ve mesleki geçmiş."
>
  <section
    class="mx-auto px-6 md:px-10 lg:px-14 pt-14 md:pt-20 pb-14"
    style="max-width: var(--container-page)"
  >
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-14 items-start">
      <div class="md:col-span-7 order-2 md:order-1">
        <p class="eyebrow mb-5">Hakkımda</p>
        <h1 class="display text-3xl md:text-4xl lg:text-5xl">
          Berk Akkoç
        </h1>
        <p class="mt-4 text-stone uppercase tracking-[0.18em] text-xs">
          Mimar · Tasarımcı
        </p>

        <div class="mt-8 space-y-5 text-sm md:text-base leading-relaxed max-w-xl text-ink-soft">
          <p>
            Şarköy merkezli mimarlık ve iç mekan tasarımı pratiği. Konuttan ticari mekânlara,
            kavramsal çalışmalardan uygulamaya farklı ölçeklerde projeler üretir.
          </p>
          <p>
            Tasarım anlayışı; mekânın günlük yaşamla nasıl ilişki kuracağını anlamak üzerine
            kuruludur. Her proje; bağlamına, kullanıcısına ve hikâyesine özgüdür.
          </p>
          <p>
            Sadelik bir stil değil bir disiplindir. Az olanın doğru olduğu yerleri araştırır;
            ışık, oran ve malzemenin diliyle çalışır.
          </p>
        </div>
      </div>

      <aside class="md:col-span-5 order-1 md:order-2">
        <div class="aspect-[4/5] bg-paper-soft border border-line overflow-hidden">
          <img
            src={u("/berk-akkoc.jpg")}
            alt="Berk Akkoç — portre"
            width="1536"
            height="2048"
            class="h-full w-full object-cover"
            loading="eager"
            decoding="async"
          />
        </div>
      </aside>
    </div>
  </section>

  <!-- ─── APPROACH ─────────────────────────────────────────── -->
  <section class="bg-paper-soft border-y border-line">
    <div
      class="mx-auto px-6 md:px-10 lg:px-14 py-16 md:py-20"
      style="max-width: var(--container-page)"
    >
      <p class="eyebrow mb-8">Üç İlke</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10">
        <div>
          <p class="display text-3xl md:text-4xl text-stone mb-3">01</p>
          <h3 class="text-base font-medium mb-2">Bağlam</h3>
          <p class="text-stone text-sm leading-relaxed">
            Her mekân, ait olduğu yerden öğrenir. Topografya, ışık ve kültür ilk girdidir.
          </p>
        </div>
        <div>
          <p class="display text-3xl md:text-4xl text-stone mb-3">02</p>
          <h3 class="text-base font-medium mb-2">Sadelik</h3>
          <p class="text-stone text-sm leading-relaxed">
            Detay azaltıldıkça anlam artar. Bir mekân; gerekli olandan fazlasını barındırmamalı.
          </p>
        </div>
        <div>
          <p class="display text-3xl md:text-4xl text-stone mb-3">03</p>
          <h3 class="text-base font-medium mb-2">Süreklilik</h3>
          <p class="text-stone text-sm leading-relaxed">
            Yapı, zamanla olgunlaşır. Malzemenin yaşlanması da tasarımın parçasıdır.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── CTA ──────────────────────────────────────────────── -->
  <section
    class="mx-auto px-6 md:px-10 lg:px-14 py-16 md:py-20 text-center"
    style="max-width: var(--container-page)"
  >
    <h2 class="display text-2xl md:text-3xl lg:text-4xl">
      Bir mekânı birlikte düşünelim
    </h2>
    <a
      href={u("/iletisim")}
      class="mt-6 inline-flex items-center gap-2 border-b border-ink pb-1 hover:text-accent hover:border-accent transition-colors text-sm"
    >
      İletişime geç <span aria-hidden="true">→</span>
    </a>
  </section>
</BaseLayout>
