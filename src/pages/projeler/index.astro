---
import BaseLayout from "~/layouts/BaseLayout.astro";
import ProjectCard from "~/components/ProjectCard.astro";
import { getCollection } from "astro:content";

const all = await getCollection("projects");
const projects = all.sort((a, b) => a.data.order - b.data.order);

const categories = ["Tümü", ...Array.from(new Set(projects.map((p) => p.data.category)))];
---

<BaseLayout
  title="Projeler"
  description="Berk Akkoç tarafından tasarlanmış konut, ticari ve iç mekan projeleri."
>
  <section
    class="mx-auto px-6 md:px-10 lg:px-14 pt-16 md:pt-24 pb-12"
    style="max-width: var(--container-page)"
  >
    <p class="eyebrow mb-6">Arşiv</p>
    <h1 class="display text-5xl md:text-7xl lg:text-8xl max-w-4xl">
      Projeler
    </h1>
    <p class="mt-8 text-stone max-w-2xl text-base md:text-lg leading-relaxed">
      Konsept çalışmalardan uygulanmış işlere, farklı ölçekteki projelerden bir seçki.
    </p>
  </section>

  <section
    class="mx-auto px-6 md:px-10 lg:px-14 pb-10 border-t border-line"
    style="max-width: var(--container-page)"
  >
    <ul
      class="flex flex-wrap gap-x-6 gap-y-2 pt-6 text-sm"
      data-filter-list
      role="list"
    >
      {categories.map((cat, i) => (
        <li>
          <button
            type="button"
            data-filter={cat}
            class:list={[
              "py-1 transition-colors hover:text-ink",
              i === 0 ? "text-ink border-b border-ink" : "text-stone",
            ]}
          >
            {cat}
          </button>
        </li>
      ))}
    </ul>
  </section>

  <section
    class="mx-auto px-6 md:px-10 lg:px-14 pb-32"
    style="max-width: var(--container-page)"
  >
    {projects.length === 0 ? (
      <p class="text-stone py-20">Henüz projeyle karşılaşmadık. Yakında.</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10" data-project-grid>
        {projects.map((p, i) => (
          <div data-category={p.data.category}>
            <ProjectCard
              href={`/projeler/${p.id}`}
              title={p.data.title}
              cover={p.data.cover}
              coverAlt={p.data.coverAlt}
              year={p.data.year}
              location={p.data.location}
              category={p.data.category}
              index={i}
            />
          </div>
        ))}
      </div>
    )}
  </section>

  <script>
    const buttons = document.querySelectorAll<HTMLButtonElement>("[data-filter]");
    const items = document.querySelectorAll<HTMLElement>("[data-category]");

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const filter = btn.dataset.filter ?? "Tümü";

        buttons.forEach((b) => {
          b.classList.remove("text-ink", "border-b", "border-ink");
          b.classList.add("text-stone");
        });
        btn.classList.remove("text-stone");
        btn.classList.add("text-ink", "border-b", "border-ink");

        items.forEach((item) => {
          const match = filter === "Tümü" || item.dataset.category === filter;
          item.style.display = match ? "" : "none";
        });
      });
    });
  </script>
</BaseLayout>
