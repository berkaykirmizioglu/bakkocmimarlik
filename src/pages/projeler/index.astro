---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { u } from "~/lib/url";
---

<BaseLayout
  title="Projeler"
  description="Berk Akkoç tarafından tasarlanmış konut, ticari ve iç mekan projeleri — yakında."
>
  <section
    class="mx-auto px-6 md:px-10 lg:px-14 pt-14 md:pt-20 pb-10"
    style="max-width: var(--container-page)"
  >
    <p class="eyebrow mb-5">İşler</p>
    <h1 class="display text-3xl md:text-5xl lg:text-6xl max-w-3xl">
      Projeler
    </h1>
  </section>

  <section
    class="mx-auto px-6 md:px-10 lg:px-14 pb-24 md:pb-32 border-t border-line pt-16 md:pt-24"
    style="max-width: var(--container-page)"
  >
    <div class="max-w-xl">
      <p class="display text-2xl md:text-3xl lg:text-4xl leading-[1.3]">
        Bu sayfa yapım aşamasındadır.
      </p>
      <p class="mt-6 text-stone text-sm md:text-base leading-relaxed">
        Projeler kısa süre içinde burada yer alacak. O zamana kadar bir
        çalışmayı konuşmak isterseniz iletişime geçebilirsiniz.
      </p>
      <a
        href={u("/iletisim")}
        class="mt-8 inline-flex items-center gap-2 text-sm border-b border-ink pb-1 hover:text-accent hover:border-accent transition-colors"
      >
        İletişime geç <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>
</BaseLayout>
