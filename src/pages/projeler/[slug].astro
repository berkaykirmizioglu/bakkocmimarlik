---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Gallery from "~/components/Gallery.astro";
import { getCollection, render } from "astro:content";
import { u } from "~/lib/url";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((p) => ({
    params: { slug: p.id },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const { data } = project;
const { Content } = await render(project);

const all = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
const currentIndex = all.findIndex((p) => p.id === project.id);
const next = all[(currentIndex + 1) % all.length];
---

<BaseLayout
  title={data.title}
  description={data.summary}
  image={data.cover}
>
  <!-- ─── COVER ───────────────────────────────────────────── -->
  <section
    class="mx-auto px-6 md:px-10 lg:px-14 pt-6"
    style="max-width: var(--container-page)"
  >
    <div class="relative aspect-[16/10] md:aspect-[16/9] overflow-hidden bg-paper-soft">
      <img
        src={u(data.cover)}
        alt={data.coverAlt ?? `${data.title} — kapak`}
        class="absolute inset-0 h-full w-full object-cover"
        loading="eager"
        decoding="async"
      />
    </div>
  </section>

  <!-- ─── HEADER ──────────────────────────────────────────── -->
  <section
    class="mx-auto px-6 md:px-10 lg:px-14 pt-10 md:pt-14 pb-10"
    style="max-width: var(--container-page)"
  >
    <p class="eyebrow mb-4">{data.category} · {data.year}</p>
    <h1 class="display text-3xl md:text-4xl lg:text-5xl max-w-3xl">
      {data.title}
    </h1>
    <p class="mt-6 text-stone text-sm md:text-base max-w-xl leading-relaxed">
      {data.summary}
    </p>
  </section>

  <!-- ─── META ────────────────────────────────────────────── -->
  <section
    class="mx-auto px-6 md:px-10 lg:px-14 pb-16 border-t border-line"
    style="max-width: var(--container-page)"
  >
    <dl class="grid grid-cols-2 md:grid-cols-4 gap-y-8 gap-x-6 pt-8 text-sm">
      <div>
        <dt class="eyebrow mb-2">Konum</dt>
        <dd>{data.location}</dd>
      </div>
      <div>
        <dt class="eyebrow mb-2">Yıl</dt>
        <dd>{data.year}</dd>
      </div>
      <div>
        <dt class="eyebrow mb-2">Tip</dt>
        <dd>{data.category}</dd>
      </div>
      <div>
        <dt class="eyebrow mb-2">Durum</dt>
        <dd>{data.status}</dd>
      </div>
      {data.client && (
        <div>
          <dt class="eyebrow mb-2">İşveren</dt>
          <dd>{data.client}</dd>
        </div>
      )}
      {data.area && (
        <div>
          <dt class="eyebrow mb-2">Alan</dt>
          <dd>{data.area}</dd>
        </div>
      )}
    </dl>
  </section>

  <!-- ─── BODY ────────────────────────────────────────────── -->
  <section
    class="mx-auto px-6 md:px-10 lg:px-14 pb-16"
    style="max-width: var(--container-page)"
  >
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
      <div class="md:col-span-8 md:col-start-3 prose-tr">
        <Content />
      </div>
    </div>
  </section>

  <!-- ─── GALLERY ─────────────────────────────────────────── -->
  {data.images.length > 0 && (
    <section
      class="mx-auto px-6 md:px-10 lg:px-14 pb-24 md:pb-32"
      style="max-width: var(--container-page)"
    >
      <Gallery images={data.images} />
    </section>
  )}

  <!-- ─── NEXT PROJECT ───────────────────────────────────── -->
  {all.length > 1 && (
    <section class="border-t border-line">
      <a
        href={u(`/projeler/${next.id}`)}
        class="block group mx-auto px-6 md:px-10 lg:px-14 py-12 md:py-16"
        style="max-width: var(--container-page)"
      >
        <p class="eyebrow mb-3">Sonraki Proje</p>
        <h2 class="display text-2xl md:text-3xl lg:text-4xl group-hover:text-accent transition-colors">
          {next.data.title} <span aria-hidden="true" class="inline-block transition-transform group-hover:translate-x-2">→</span>
        </h2>
      </a>
    </section>
  )}
</BaseLayout>
