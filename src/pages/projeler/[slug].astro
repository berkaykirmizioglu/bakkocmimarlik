---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Gallery from "~/components/Gallery.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((p) => ({
    params: { slug: p.id },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const { data } = project;
const { Content } = await render(project);

const all = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
const currentIndex = all.findIndex((p) => p.id === project.id);
const next = all[(currentIndex + 1) % all.length];
---

<BaseLayout
  title={data.title}
  description={data.summary}
  image={data.cover}
>
  <!-- ─── COVER ───────────────────────────────────────────── -->
  <section class="relative">
    <div class="relative aspect-[16/10] md:aspect-[21/9] overflow-hidden bg-paper-soft">
      <img
        src={data.cover}
        alt={data.coverAlt ?? `${data.title} — kapak`}
        class="absolute inset-0 h-full w-full object-cover"
        loading="eager"
        decoding="async"
      />
    </div>
  </section>

  <!-- ─── HEADER ──────────────────────────────────────────── -->
  <section
    class="mx-auto px-6 md:px-10 lg:px-14 pt-12 md:pt-16 pb-12 md:pb-16"
    style="max-width: var(--container-page)"
  >
    <p class="eyebrow mb-6">{data.category} · {data.year}</p>
    <h1 class="display text-4xl md:text-6xl lg:text-7xl max-w-4xl">
      {data.title}
    </h1>
    <p class="mt-8 text-stone text-base md:text-lg max-w-2xl leading-relaxed">
      {data.summary}
    </p>
  </section>

  <!-- ─── META ────────────────────────────────────────────── -->
  <section
    class="mx-auto px-6 md:px-10 lg:px-14 pb-16 border-t border-line"
    style="max-width: var(--container-page)"
  >
    <dl class="grid grid-cols-2 md:grid-cols-4 gap-y-8 gap-x-6 pt-8 text-sm">
      <div>
        <dt class="eyebrow mb-2">Konum</dt>
        <dd>{data.location}</dd>
      </div>
      <div>
        <dt class="eyebrow mb-2">Yıl</dt>
        <dd>{data.year}</dd>
      </div>
      <div>
        <dt class="eyebrow mb-2">Tip</dt>
        <dd>{data.category}</dd>
      </div>
      <div>
        <dt class="eyebrow mb-2">Durum</dt>
        <dd>{data.status}</dd>
      </div>
      {data.client && (
        <div>
          <dt class="eyebrow mb-2">İşveren</dt>
          <dd>{data.client}</dd>
        </div>
      )}
      {data.area && (
        <div>
          <dt class="eyebrow mb-2">Alan</dt>
          <dd>{data.area}</dd>
        </div>
      )}
    </dl>
  </section>

  <!-- ─── BODY ────────────────────────────────────────────── -->
  <section
    class="mx-auto px-6 md:px-10 lg:px-14 pb-16"
    style="max-width: var(--container-page)"
  >
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
      <div class="md:col-span-8 md:col-start-3 prose-tr">
        <Content />
      </div>
    </div>
  </section>

  <!-- ─── GALLERY ─────────────────────────────────────────── -->
  {data.images.length > 0 && (
    <section
      class="mx-auto px-6 md:px-10 lg:px-14 pb-24 md:pb-32"
      style="max-width: var(--container-page)"
    >
      <Gallery images={data.images} />
    </section>
  )}

  <!-- ─── NEXT PROJECT ───────────────────────────────────── -->
  {next && next.id !== project.id && (
    <section class="border-t border-line">
      <a
        href={`/projeler/${next.id}`}
        class="block group mx-auto px-6 md:px-10 lg:px-14 py-16 md:py-24"
        style="max-width: var(--container-page)"
      >
        <p class="eyebrow mb-4">Sonraki Proje</p>
        <h2 class="display text-4xl md:text-6xl group-hover:text-accent transition-colors">
          {next.data.title} <span aria-hidden="true" class="inline-block transition-transform group-hover:translate-x-2">→</span>
        </h2>
      </a>
    </section>
  )}
</BaseLayout>

<style is:global>
  .prose-tr {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--color-ink-soft);
  }
  .prose-tr p {
    margin-block: 1.1em;
  }
  .prose-tr h2 {
    font-family: var(--font-display);
    letter-spacing: var(--tracking-tighter);
    font-weight: 300;
    font-size: 1.75rem;
    margin-top: 2.5em;
    margin-bottom: 0.6em;
    color: var(--color-ink);
  }
  .prose-tr h3 {
    font-weight: 500;
    font-size: 1.15rem;
    margin-top: 2em;
    margin-bottom: 0.4em;
    color: var(--color-ink);
  }
  .prose-tr blockquote {
    border-left: 2px solid var(--color-ink);
    padding-left: 1.25rem;
    margin: 2em 0;
    font-style: italic;
    color: var(--color-ink);
  }
  .prose-tr a {
    color: var(--color-ink);
    border-bottom: 1px solid var(--color-line);
    transition: border-color 0.2s;
  }
  .prose-tr a:hover {
    border-bottom-color: var(--color-ink);
  }
  .prose-tr ul,
  .prose-tr ol {
    padding-left: 1.25rem;
    margin-block: 1.1em;
  }
  .prose-tr li {
    margin-block: 0.35em;
  }
</style>
