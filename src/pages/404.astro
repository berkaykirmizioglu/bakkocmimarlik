---
import BaseLayout from "~/layouts/BaseLayout.astro";
---

<BaseLayout title="Sayfa bulunamadı" noindex>
  <section
    class="mx-auto px-6 md:px-10 lg:px-14 py-24 md:py-32 text-center"
    style="max-width: var(--container-page)"
  >
    <p class="eyebrow mb-5">404</p>
    <h1 class="display text-3xl md:text-5xl max-w-2xl mx-auto">
      Bu mekân<br />henüz inşa edilmedi.
    </h1>
    <a
      href="/"
      class="mt-8 inline-flex items-center gap-2 border-b border-ink pb-1 hover:text-accent hover:border-accent transition-colors text-sm"
    >
      Ana sayfaya dön <span aria-hidden="true">→</span>
    </a>
  </section>
</BaseLayout>
