---
import BaseLayout from "~/layouts/BaseLayout.astro";
---

<BaseLayout title="Sayfa bulunamadı" noindex>
  <section
    class="mx-auto px-6 md:px-10 lg:px-14 py-32 md:py-44 text-center"
    style="max-width: var(--container-page)"
  >
    <p class="eyebrow mb-6">404</p>
    <h1 class="display text-5xl md:text-7xl max-w-3xl mx-auto">
      Bu mekân<br />henüz inşa edilmedi.
    </h1>
    <a
      href="/"
      class="mt-10 inline-flex items-center gap-2 border-b border-ink pb-1 hover:text-accent hover:border-accent transition-colors"
    >
      Ana sayfaya dön <span aria-hidden="true">→</span>
    </a>
  </section>
</BaseLayout>
