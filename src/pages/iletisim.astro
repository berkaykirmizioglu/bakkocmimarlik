---
import BaseLayout from "~/layouts/BaseLayout.astro";

const email = "b.akkocmimarlik@gmail.com";
const phoneDisplay = "+90 544 480 59 59";
const phoneIntl = "905444805959";
const address = "İstiklal Mah. Ahmet Doğan Küçük Sk. No:5/A Şarköy / Tekirdağ";
const mapsUrl =
  "https://www.google.com/maps/search/?api=1&query=" +
  encodeURIComponent(address);

const channels = [
  { label: "E-posta", value: email, href: `mailto:${email}` },
  { label: "Telefon", value: phoneDisplay, href: `tel:+${phoneIntl}` },
  { label: "WhatsApp", value: phoneDisplay, href: `https://wa.me/${phoneIntl}` },
  { label: "Adres", value: address, href: mapsUrl },
];
---

<BaseLayout
  title="İletişim"
  description="Berk Akkoç ile iletişim — proje, danışma ve işbirliği talepleri."
>
  <section
    class="mx-auto px-6 md:px-10 lg:px-14 pt-14 md:pt-20 pb-10"
    style="max-width: var(--container-page)"
  >
    <p class="eyebrow mb-5">İletişim</p>
    <h1 class="display text-3xl md:text-5xl lg:text-6xl max-w-3xl">
      Yeni bir<br />projeniz mi var?
    </h1>
    <a
      href={`mailto:${email}`}
      class="mt-8 inline-flex items-center gap-3 display text-lg md:text-2xl border-b border-ink pb-1 hover:text-accent hover:border-accent transition-colors"
    >
      {email}
      <span aria-hidden="true">→</span>
    </a>
  </section>

  <section
    class="mx-auto px-6 md:px-10 lg:px-14 py-14 grid grid-cols-1 md:grid-cols-12 gap-10 border-t border-line"
    style="max-width: var(--container-page)"
  >
    <div class="md:col-span-7">
      <p class="eyebrow mb-5">Kanallar</p>
      <ul class="divide-y divide-line">
        {channels.map((c) => (
          <li class="py-5 flex items-baseline justify-between gap-6">
            <span class="text-stone text-sm shrink-0">{c.label}</span>
            {c.href ? (
              <a
                href={c.href}
                target={c.href.startsWith("http") ? "_blank" : undefined}
                rel={c.href.startsWith("http") ? "noopener noreferrer" : undefined}
                class="text-base md:text-lg text-right hover:text-ink"
              >
                {c.value}
              </a>
            ) : (
              <span class="text-base md:text-lg text-right">{c.value}</span>
            )}
          </li>
        ))}
      </ul>
    </div>

    <div class="md:col-span-5">
      <p class="eyebrow mb-5">İlk mesajınız için</p>
      <p class="text-sm md:text-base text-stone leading-relaxed max-w-md">
        Projenin konumu, kullanım amacı ve yaklaşık brüt alanını paylaşırsanız
        ilk görüşmeye birkaç düşünceyle gelirim. Hızla geri dönüş yapıyorum.
      </p>
    </div>
  </section>
</BaseLayout>
