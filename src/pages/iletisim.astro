---
import BaseLayout from "~/layouts/BaseLayout.astro";

const email = "info@bakkocmimarlik.com";
const phone = "+90 555 000 00 00";

const channels = [
  { label: "E-posta", value: email, href: `mailto:${email}` },
  { label: "Telefon", value: phone, href: `tel:${phone.replace(/\s/g, "")}` },
  { label: "Konum", value: "İstanbul, Türkiye", href: null },
];

const social = [
  { label: "Instagram", handle: "@berkakkoc", href: "https://instagram.com/" },
  { label: "LinkedIn", handle: "Berk Akkoç", href: "https://linkedin.com/" },
  { label: "Behance", handle: "berkakkoc", href: "https://behance.net/" },
];
---

<BaseLayout
  title="İletişim"
  description="Berk Akkoç ile iletişim — proje, danışma ve işbirliği talepleri."
>
  <section
    class="mx-auto px-6 md:px-10 lg:px-14 pt-16 md:pt-24 pb-12"
    style="max-width: var(--container-page)"
  >
    <p class="eyebrow mb-6">İletişim</p>
    <h1 class="display text-5xl md:text-7xl lg:text-8xl max-w-4xl">
      Yeni bir<br />projeniz mi var?
    </h1>
    <a
      href={`mailto:${email}`}
      class="mt-10 inline-flex items-center gap-3 display text-2xl md:text-4xl border-b border-ink pb-2 hover:text-accent hover:border-accent transition-colors"
    >
      {email}
      <span aria-hidden="true">→</span>
    </a>
  </section>

  <section
    class="mx-auto px-6 md:px-10 lg:px-14 py-16 grid grid-cols-1 md:grid-cols-12 gap-10 border-t border-line"
    style="max-width: var(--container-page)"
  >
    <div class="md:col-span-7">
      <p class="eyebrow mb-6">Kanallar</p>
      <ul class="divide-y divide-line">
        {channels.map((c) => (
          <li class="py-5 flex items-baseline justify-between gap-6">
            <span class="text-stone text-sm">{c.label}</span>
            {c.href ? (
              <a href={c.href} class="text-base md:text-lg hover:text-ink">{c.value}</a>
            ) : (
              <span class="text-base md:text-lg">{c.value}</span>
            )}
          </li>
        ))}
      </ul>
    </div>

    <div class="md:col-span-5">
      <p class="eyebrow mb-6">Sosyal</p>
      <ul class="divide-y divide-line">
        {social.map((s) => (
          <li class="py-5 flex items-baseline justify-between gap-6">
            <span class="text-stone text-sm">{s.label}</span>
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-base md:text-lg hover:text-ink"
            >
              {s.handle}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section
    class="mx-auto px-6 md:px-10 lg:px-14 py-20 md:py-28 border-t border-line"
    style="max-width: var(--container-page)"
  >
    <p class="eyebrow mb-6">Çalışma Saatleri</p>
    <p class="display text-2xl md:text-4xl max-w-3xl leading-tight">
      Pazartesi – Cuma, <span class="text-stone">09:00 – 18:00</span>.
      Görüşme talepleri için e-posta tercih edilir.
    </p>
  </section>
</BaseLayout>
