---
import BaseLayout from "~/layouts/BaseLayout.astro";
import ProjectCard from "~/components/ProjectCard.astro";
import { getCollection } from "astro:content";
import { u } from "~/lib/url";

const projects = await getCollection("projects");
const featured = projects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<BaseLayout
  title="Tasarım & Mimarlık"
  description="Berk Akkoç — sade, sakin ve içeriden gelen bir mimarlık pratiği. Konut, ticari ve iç mekan projeleri."
>
  <!-- ─── HERO ─────────────────────────────────────────────── -->
  <section
    class="mx-auto px-6 md:px-10 lg:px-14 pt-16 md:pt-24 lg:pt-28 pb-16 md:pb-24"
    style="max-width: var(--container-page)"
  >
    <p class="eyebrow mb-6 rise">Tasarım & Mimarlık · İstanbul</p>
    <h1 class="display text-[clamp(1.875rem,5.5vw,3.75rem)] max-w-3xl rise" style="animation-delay: 80ms">
      Sade hatların<br />
      <span class="italic font-light">sakin</span> mekânları.
    </h1>
    <div class="mt-10 md:mt-12 grid grid-cols-1 md:grid-cols-12 gap-8 rise" style="animation-delay: 160ms">
      <p class="md:col-span-7 md:col-start-5 text-stone text-sm md:text-base leading-relaxed max-w-xl">
        Berk Akkoç; iç mekândan kentsel ölçeğe uzanan bir tasarım pratiği yürütür.
        Her proje; ışık, malzeme ve oran üzerine yeniden kurulan bir hikâyedir.
      </p>
    </div>
  </section>

  <!-- ─── FEATURED PROJECTS ────────────────────────────────── -->
  <section
    class="mx-auto px-6 md:px-10 lg:px-14 pb-24 md:pb-32"
    style="max-width: var(--container-page)"
  >
    <div class="flex items-end justify-between mb-8 md:mb-12 border-t border-line pt-6">
      <div>
        <p class="eyebrow mb-2">Seçili İşler</p>
        <h2 class="display text-2xl md:text-3xl lg:text-4xl">Son projeler</h2>
      </div>
      <a
        href={u("/projeler")}
        class="hidden sm:inline-flex items-center gap-2 text-sm border-b border-ink pb-1 hover:text-accent hover:border-accent transition-colors"
      >
        Tüm projeler <span aria-hidden="true">→</span>
      </a>
    </div>

    {featured.length === 0 ? (
      <p class="text-stone">Henüz öne çıkarılmış proje yok.</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10">
        {featured.map((p, i) => (
          <ProjectCard
            href={`/projeler/${p.id}`}
            title={p.data.title}
            cover={p.data.cover}
            coverAlt={p.data.coverAlt}
            year={p.data.year}
            location={p.data.location}
            category={p.data.category}
            index={i}
          />
        ))}
      </div>
    )}

    <div class="sm:hidden mt-10">
      <a
        href={u("/projeler")}
        class="inline-flex items-center gap-2 text-sm border-b border-ink pb-1"
      >
        Tüm projeler <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  <!-- ─── PHILOSOPHY ───────────────────────────────────────── -->
  <section class="bg-paper-soft border-y border-line">
    <div
      class="mx-auto px-6 md:px-10 lg:px-14 py-16 md:py-24 grid grid-cols-1 md:grid-cols-12 gap-8"
      style="max-width: var(--container-page)"
    >
      <p class="eyebrow md:col-span-3">Yaklaşım</p>
      <div class="md:col-span-9">
        <p class="display text-xl md:text-2xl lg:text-3xl leading-[1.3] max-w-3xl">
          Bir mekânı tasarlamak; ışığı, sessizliği ve günü
          birlikte düşünmektir. Her detay; yaşamı kolaylaştırmak için vardır.
        </p>
        <a
          href={u("/hakkimda")}
          class="mt-8 inline-flex items-center gap-2 text-sm border-b border-ink pb-1 hover:text-accent hover:border-accent transition-colors"
        >
          Hakkımda <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ─── CTA ──────────────────────────────────────────────── -->
  <section
    class="mx-auto px-6 md:px-10 lg:px-14 py-20 md:py-28 text-center"
    style="max-width: var(--container-page)"
  >
    <p class="eyebrow mb-5">Çalışmak ister misiniz?</p>
    <h2 class="display text-3xl md:text-4xl lg:text-5xl max-w-2xl mx-auto">
      Bir mekânı<br />
      birlikte düşünelim.
    </h2>
    <a
      href={u("/iletisim")}
      class="mt-8 inline-flex items-center gap-2 text-sm border-b border-ink pb-1 hover:text-accent hover:border-accent transition-colors"
    >
      İletişime geç <span aria-hidden="true">→</span>
    </a>
  </section>
</BaseLayout>
