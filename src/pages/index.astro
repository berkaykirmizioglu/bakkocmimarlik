---
import BaseLayout from "~/layouts/BaseLayout.astro";
import ProjectCard from "~/components/ProjectCard.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
const featured = projects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<BaseLayout
  title="Tasarım & Mimarlık"
  description="Berk Akkoç — sade, sakin ve içeriden gelen bir mimarlık pratiği. Konut, ticari ve iç mekan projeleri."
>
  <!-- ─── HERO ─────────────────────────────────────────────── -->
  <section
    class="mx-auto px-6 md:px-10 lg:px-14 pt-20 md:pt-32 lg:pt-44 pb-24 md:pb-40"
    style="max-width: var(--container-page)"
  >
    <p class="eyebrow mb-8 rise">Tasarım & Mimarlık · İstanbul</p>
    <h1 class="display text-[clamp(2.5rem,9vw,8rem)] max-w-5xl rise" style="animation-delay: 80ms">
      Sade hatların<br />
      <span class="italic font-light">sakin</span> mekânları.
    </h1>
    <div class="mt-12 md:mt-16 grid grid-cols-1 md:grid-cols-12 gap-8 rise" style="animation-delay: 160ms">
      <p class="md:col-span-6 md:col-start-7 text-stone text-base md:text-lg leading-relaxed max-w-xl">
        Berk Akkoç; iç mekândan kentsel ölçeğe uzanan bir tasarım pratiği yürütür.
        Her proje; ışık, malzeme ve oran üzerine yeniden kurulan bir hikâyedir.
      </p>
    </div>
  </section>

  <!-- ─── FEATURED PROJECTS ────────────────────────────────── -->
  <section
    class="mx-auto px-6 md:px-10 lg:px-14 pb-24 md:pb-32"
    style="max-width: var(--container-page)"
  >
    <div class="flex items-end justify-between mb-10 md:mb-14 border-t border-line pt-8">
      <div>
        <p class="eyebrow mb-3">Seçili İşler</p>
        <h2 class="display text-3xl md:text-5xl">Son projeler</h2>
      </div>
      <a
        href="/projeler"
        class="hidden sm:inline-flex items-center gap-2 text-sm border-b border-ink pb-1 hover:text-accent hover:border-accent transition-colors"
      >
        Tüm projeler <span aria-hidden="true">→</span>
      </a>
    </div>

    {featured.length === 0 ? (
      <p class="text-stone">Henüz öne çıkarılmış proje yok.</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-8">
        {featured.map((p, i) => (
          <div
            class:list={[
              i === 0 ? "md:col-span-7" : "md:col-span-5",
              i === 1 ? "md:mt-16" : "",
              i === 2 ? "md:col-span-7 md:col-start-4" : "",
            ]}
          >
            <ProjectCard
              href={`/projeler/${p.id}`}
              title={p.data.title}
              cover={p.data.cover}
              coverAlt={p.data.coverAlt}
              year={p.data.year}
              location={p.data.location}
              category={p.data.category}
              ratio={i === 1 ? "portrait" : "landscape"}
              index={i}
            />
          </div>
        ))}
      </div>
    )}

    <div class="sm:hidden mt-10">
      <a
        href="/projeler"
        class="inline-flex items-center gap-2 text-sm border-b border-ink pb-1"
      >
        Tüm projeler <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  <!-- ─── PHILOSOPHY ───────────────────────────────────────── -->
  <section class="bg-paper-soft border-y border-line">
    <div
      class="mx-auto px-6 md:px-10 lg:px-14 py-24 md:py-32 grid grid-cols-1 md:grid-cols-12 gap-10"
      style="max-width: var(--container-page)"
    >
      <p class="eyebrow md:col-span-3">Yaklaşım</p>
      <div class="md:col-span-9">
        <p class="display text-2xl md:text-4xl lg:text-5xl leading-[1.15] max-w-4xl">
          Bir mekânı tasarlamak; ışığı, sessizliği ve günü
          birlikte düşünmektir. Her detay; yaşamı kolaylaştırmak için vardır.
        </p>
        <a
          href="/hakkimda"
          class="mt-10 inline-flex items-center gap-2 text-sm border-b border-ink pb-1 hover:text-accent hover:border-accent transition-colors"
        >
          Hakkımda <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ─── CTA ──────────────────────────────────────────────── -->
  <section
    class="mx-auto px-6 md:px-10 lg:px-14 py-24 md:py-32 text-center"
    style="max-width: var(--container-page)"
  >
    <p class="eyebrow mb-6">Çalışmak ister misiniz?</p>
    <h2 class="display text-4xl md:text-6xl lg:text-7xl max-w-3xl mx-auto">
      Bir mekânı<br />
      birlikte düşünelim.
    </h2>
    <a
      href="/iletisim"
      class="mt-10 inline-flex items-center gap-3 bg-ink text-paper px-8 py-4 text-sm hover:bg-ink-soft transition-colors"
    >
      İletişime geç <span aria-hidden="true">→</span>
    </a>
  </section>
</BaseLayout>
