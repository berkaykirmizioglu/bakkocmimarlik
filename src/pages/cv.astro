---
import BaseLayout from "~/layouts/BaseLayout.astro";

const education = [
  { year: "2020 – 2025", title: "Mimarlık Lisans", place: "Üniversite Adı, İstanbul" },
  { year: "2016 – 2020", title: "Lise", place: "Lise Adı" },
];

const experience = [
  { year: "2025 – ...", title: "Bağımsız Mimar", place: "Berk Akkoç Tasarım & Mimarlık" },
  { year: "2024 – 2025", title: "Mimar Yardımcısı", place: "Stüdyo Adı, İstanbul" },
  { year: "2023", title: "Staj", place: "Stüdyo Adı" },
];

const skills = [
  "Konsept Tasarım",
  "Detay & Uygulama Projesi",
  "İç Mekan Tasarımı",
  "AutoCAD",
  "Revit / BIM",
  "Rhinoceros + Grasshopper",
  "SketchUp",
  "Adobe Suite",
  "V-Ray / Enscape",
];

const exhibitions = [
  { year: "2024", title: "Öğrenci Sergisi", place: "Galeri Adı" },
];
---

<BaseLayout
  title="CV"
  description="Berk Akkoç — özgeçmiş, eğitim, deneyim ve yetkinlikler."
>
  <section
    class="mx-auto px-6 md:px-10 lg:px-14 pt-16 md:pt-24 pb-10"
    style="max-width: var(--container-page)"
  >
    <div class="flex flex-col md:flex-row items-start md:items-end justify-between gap-6">
      <div>
        <p class="eyebrow mb-6">Özgeçmiş</p>
        <h1 class="display text-5xl md:text-7xl">CV</h1>
      </div>
      <a
        href="/cv/berk-akkoc-cv.pdf"
        download
        class="inline-flex items-center gap-3 bg-ink text-paper px-6 py-3 text-sm hover:bg-ink-soft transition-colors"
      >
        PDF olarak indir <span aria-hidden="true">↓</span>
      </a>
    </div>
  </section>

  <section
    class="mx-auto px-6 md:px-10 lg:px-14 pb-20 grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-12 border-t border-line pt-12"
    style="max-width: var(--container-page)"
  >
    <!-- Sol kolon -->
    <div class="md:col-span-7 space-y-14">
      <div>
        <p class="eyebrow mb-6">Deneyim</p>
        <ul class="divide-y divide-line">
          {experience.map((e) => (
            <li class="py-5 flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-6">
              <span class="text-stone text-sm sm:w-32 shrink-0">{e.year}</span>
              <div>
                <p class="font-medium">{e.title}</p>
                <p class="text-stone text-sm">{e.place}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="eyebrow mb-6">Eğitim</p>
        <ul class="divide-y divide-line">
          {education.map((e) => (
            <li class="py-5 flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-6">
              <span class="text-stone text-sm sm:w-32 shrink-0">{e.year}</span>
              <div>
                <p class="font-medium">{e.title}</p>
                <p class="text-stone text-sm">{e.place}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>

      {exhibitions.length > 0 && (
        <div>
          <p class="eyebrow mb-6">Sergi & Yayın</p>
          <ul class="divide-y divide-line">
            {exhibitions.map((e) => (
              <li class="py-5 flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-6">
                <span class="text-stone text-sm sm:w-32 shrink-0">{e.year}</span>
                <div>
                  <p class="font-medium">{e.title}</p>
                  <p class="text-stone text-sm">{e.place}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>

    <!-- Sağ kolon -->
    <aside class="md:col-span-5 space-y-14">
      <div>
        <p class="eyebrow mb-6">Yetkinlikler</p>
        <ul class="flex flex-wrap gap-2">
          {skills.map((s) => (
            <li class="border border-line px-3 py-1.5 text-sm">{s}</li>
          ))}
        </ul>
      </div>

      <div>
        <p class="eyebrow mb-6">Diller</p>
        <ul class="space-y-2 text-sm">
          <li class="flex justify-between"><span>Türkçe</span><span class="text-stone">Anadil</span></li>
          <li class="flex justify-between"><span>İngilizce</span><span class="text-stone">İleri</span></li>
        </ul>
      </div>

      <div>
        <p class="eyebrow mb-6">İletişim</p>
        <ul class="space-y-2 text-sm">
          <li><a href="mailto:info@bakkocmimarlik.com" class="hover:text-ink text-stone">info@bakkocmimarlik.com</a></li>
          <li class="text-stone">İstanbul, Türkiye</li>
        </ul>
      </div>
    </aside>
  </section>
</BaseLayout>
