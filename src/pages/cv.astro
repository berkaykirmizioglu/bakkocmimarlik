---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { u } from "~/lib/url";

// CV içeriği gerçek bilgilerle dolana kadar sayfa "yakında" modunda.
// Hazır olunca cvDraft=false yap, eğitim/deneyim/yetkinlik dizilerini doldur,
// public/cv/berk-akkoc-cv.pdf'i yükle ve cvPdfAvailable=true yap.
const cvDraft = true;
const cvPdfAvailable = false;

const education: { year: string; title: string; place: string }[] = [];
const experience: { year: string; title: string; place: string }[] = [];
const skills: string[] = [];
const exhibitions: { year: string; title: string; place: string }[] = [];
---

<BaseLayout
  title="CV"
  description="Berk Akkoç — özgeçmiş, eğitim, deneyim ve yetkinlikler."
>
  <section
    class="mx-auto px-6 md:px-10 lg:px-14 pt-14 md:pt-20 pb-8"
    style="max-width: var(--container-page)"
  >
    <div class="flex flex-col md:flex-row items-start md:items-end justify-between gap-5">
      <div>
        <p class="eyebrow mb-4">Özgeçmiş</p>
        <h1 class="display text-3xl md:text-5xl lg:text-6xl">CV</h1>
      </div>
      {cvPdfAvailable ? (
        <a
          href={u("/cv/berk-akkoc-cv.pdf")}
          download
          type="application/pdf"
          class="inline-flex items-center gap-3 bg-ink text-paper px-6 py-3 text-sm hover:bg-ink-soft transition-colors"
        >
          PDF olarak indir <span aria-hidden="true">↓</span>
        </a>
      ) : (
        <p class="text-stone text-sm">PDF versiyonu yakında.</p>
      )}
    </div>
  </section>

  {cvDraft && (
    <section
      class="mx-auto px-6 md:px-10 lg:px-14 pb-20 border-t border-line pt-12"
      style="max-width: var(--container-page)"
    >
      <p class="display text-2xl md:text-3xl text-stone max-w-2xl leading-snug">
        Özgeçmiş içeriği yakında yayında.
        Bu arada projeler ve iletişim bilgileri öbür sayfalarda yer alıyor.
      </p>
      <div class="mt-8 flex flex-wrap gap-x-6 gap-y-3 text-sm">
        <a href={u("/projeler")} class="border-b border-ink pb-1 hover:text-accent hover:border-accent transition-colors">
          Projeler <span aria-hidden="true">→</span>
        </a>
        <a href={u("/iletisim")} class="border-b border-ink pb-1 hover:text-accent hover:border-accent transition-colors">
          İletişim <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>
  )}

  {!cvDraft && (
  <section
    class="mx-auto px-6 md:px-10 lg:px-14 pb-20 grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-12 border-t border-line pt-10"
    style="max-width: var(--container-page)"
  >
    <!-- Sol kolon -->
    <div class="md:col-span-7 space-y-14">
      <div>
        <p class="eyebrow mb-6">Deneyim</p>
        <ul class="divide-y divide-line">
          {experience.map((e) => (
            <li class="py-5 flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-6">
              <span class="text-stone text-sm sm:w-32 shrink-0">{e.year}</span>
              <div>
                <p class="font-medium">{e.title}</p>
                <p class="text-stone text-sm">{e.place}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="eyebrow mb-6">Eğitim</p>
        <ul class="divide-y divide-line">
          {education.map((e) => (
            <li class="py-5 flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-6">
              <span class="text-stone text-sm sm:w-32 shrink-0">{e.year}</span>
              <div>
                <p class="font-medium">{e.title}</p>
                <p class="text-stone text-sm">{e.place}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>

      {exhibitions.length > 0 && (
        <div>
          <p class="eyebrow mb-6">Sergi & Yayın</p>
          <ul class="divide-y divide-line">
            {exhibitions.map((e) => (
              <li class="py-5 flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-6">
                <span class="text-stone text-sm sm:w-32 shrink-0">{e.year}</span>
                <div>
                  <p class="font-medium">{e.title}</p>
                  <p class="text-stone text-sm">{e.place}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>

    <!-- Sağ kolon -->
    <aside class="md:col-span-5 space-y-14">
      <div>
        <p class="eyebrow mb-6">Yetkinlikler</p>
        <ul class="flex flex-wrap gap-2">
          {skills.map((s) => (
            <li class="border border-line px-3 py-1.5 text-sm">{s}</li>
          ))}
        </ul>
      </div>

      <div>
        <p class="eyebrow mb-6">Diller</p>
        <ul class="space-y-2 text-sm">
          <li class="flex justify-between"><span>Türkçe</span><span class="text-stone">Anadil</span></li>
          <li class="flex justify-between"><span>İngilizce</span><span class="text-stone">İleri</span></li>
        </ul>
      </div>

      <div>
        <p class="eyebrow mb-6">İletişim</p>
        <ul class="space-y-2 text-sm">
          <li><a href="mailto:info@bakkocmimarlik.com" class="hover:text-ink text-stone">info@bakkocmimarlik.com</a></li>
          <li class="text-stone">İstanbul, Türkiye</li>
        </ul>
      </div>
    </aside>
  </section>
  )}
</BaseLayout>
