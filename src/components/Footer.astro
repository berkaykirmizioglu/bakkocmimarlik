---
const year = new Date().getFullYear();
const email = "b.akkocmimarlik@gmail.com";
---

<footer class="border-t border-line mt-20 md:mt-28">
  <div
    class="mx-auto px-6 md:px-10 lg:px-14 py-12 md:py-16 grid grid-cols-1 md:grid-cols-12 gap-10"
    style="max-width: var(--container-page)"
  >
    <div class="md:col-span-7">
      <p class="display text-xl md:text-2xl lg:text-3xl max-w-md">
        Projenizi anlatın.
      </p>
      <a
        href={`mailto:${email}`}
        class="mt-5 inline-flex items-center gap-2 border-b border-ink pb-1 text-sm hover:text-accent hover:border-accent transition-colors"
      >
        {email}
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="md:col-span-5 md:text-right">
      <p class="eyebrow mb-3">Stüdyo</p>
      <p class="text-sm text-stone">Şarköy, Tekirdağ</p>
    </div>
  </div>

  <div class="border-t border-line">
    <div
      class="mx-auto px-6 md:px-10 lg:px-14 py-6 flex items-center justify-between gap-2 text-xs text-stone"
      style="max-width: var(--container-page)"
    >
      <p>© {year} Berk Akkoç — Tasarım & Mimarlık.</p>
    </div>
  </div>
</footer>
