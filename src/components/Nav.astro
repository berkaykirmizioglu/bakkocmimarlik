---
const { pathname } = Astro.url;
const isHome = pathname === "/" || pathname === "";
const links = [
  { href: "/projeler", label: "Projeler" },
  { href: "/hakkimda", label: "Hakkımda" },
  { href: "/cv", label: "CV" },
  { href: "/iletisim", label: "İletişim" },
];
function isActive(href: string) {
  if (href === "/") return isHome;
  return pathname === href || pathname.startsWith(href + "/");
}
---

<header class="sticky top-0 z-50 bg-paper/85 backdrop-blur-md border-b border-line">
  <nav
    class="mx-auto flex items-center justify-between px-6 md:px-10 lg:px-14 py-5"
    style="max-width: var(--container-page)"
    aria-label="Ana gezinme"
  >
    <a
      href="/"
      class="flex items-center gap-3 group"
      aria-label="Ana sayfa — Berk Akkoç Tasarım & Mimarlık"
    >
      <span
        class="inline-flex h-9 w-9 items-center justify-center border border-ink text-ink font-medium tracking-tighter text-lg group-hover:bg-ink group-hover:text-paper transition-colors duration-300"
        aria-hidden="true"
      >
        B
      </span>
      <span class="hidden sm:flex flex-col leading-tight">
        <span class="text-sm font-medium tracking-tighter">Berk Akkoç</span>
        <span class="eyebrow" style="font-size: 0.62rem">Tasarım & Mimarlık</span>
      </span>
    </a>

    <ul class="flex items-center gap-1 sm:gap-2 md:gap-4 text-sm">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            class:list={[
              "px-2 sm:px-3 py-2 transition-colors duration-200 hover:text-ink",
              isActive(l.href) ? "text-ink" : "text-stone",
            ]}
            aria-current={isActive(l.href) ? "page" : undefined}
          >
            {l.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
